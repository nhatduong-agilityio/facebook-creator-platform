NODE_ENV=test
PORT=3001

# Separate test database — never share with dev
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/fcp_test

# Redis (same instance, different queue prefix in tests)
REDIS_HOST=localhost
REDIS_PORT=6379

# Clerk (mocked in tests — value doesn't matter)
CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Stripe (mocked in tests)
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_test_mock

# Facebook (mocked in tests)
FACEBOOK_APP_ID=test_app_id
FACEBOOK_APP_SECRET=test_app_secret
FACEBOOK_WEBHOOK_VERIFY_TOKEN=test_verify_token
